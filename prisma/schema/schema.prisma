// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"

  output = "../generated"

  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS (Dominios de datos estrictos oficiales)
// ==========================================

enum Role {
  ADMIN // Director / Administrador principal
  SECRETARIA // Secretaría Académica
  DOCENTE // Plantel Docente (Web & App)
  PADRE // Para la App Móvil
  ESTUDIANTE // Para la App Móvil
}

enum UserStatus {
  ACTIVE // Puede ingresar al sistema
  INACTIVE // Cuenta bloqueada/suspendida
}

enum DependencyType {
  FISCAL // Público
  PRIVADA // Privado
  CONVENIO // Mixto / Iglesia
}

enum Department {
  CHUQUISACA
  LA_PAZ
  COCHABAMBA
  ORURO
  POTOSI
  TARIJA
  SANTA_CRUZ
  BENI
  PANDO
}

enum Shift {
  MANANA
  TARDE
  NOCHE
}

enum EducationLevel {
  INICIAL
  PRIMARIA
  SECUNDARIA
}

// ==========================================
// MODELOS
// ==========================================

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String // Hash de la contraseña (NUNCA en texto plano)
  fullName String @map("full_name")

  // Control de Accesos
  role   Role       @default(DOCENTE)
  status UserStatus @default(ACTIVE)

  // Flujo de Onboarding (Setup Password)
  requiresPasswordChange Boolean @default(true) @map("requires_password_change")

  // Auditoría
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // --- NUEVOS CAMPOS DE PERFIL ---
  ci        String? // Carnet de Identidad
  phone     String? // Teléfono
  address   String? // Dirección
  specialty String? // Especialidad (Ej. Matemáticas)

  // ==========================================
  // RELACIONES CON INSTITUCIÓN
  // ==========================================

  // 1. Relación: El colegio donde trabaja este usuario (Docente, Secretaria o Admin)
  institutionId String?      @map("institution_id")
  institution   Institution? @relation("InstitutionStaff", fields: [institutionId], references: [id])

  // 2. Relación Inversa: El colegio que este usuario dirige (Solo aplica si es el Director General)
  directedInstitution Institution?        @relation("InstitutionDirector")
  classrooms          Classroom[]         @relation("ClassroomAdvisor")
  teacherAssignments  TeacherAssignment[] @relation("TeacherAssignments")
  scheduleSlots       ScheduleSlot[]

  // ==========================================
  // RELACIONES PARA LA APP MÓVIL
  // ==========================================
  // Si este usuario es un padre, se conecta a su registro físico de Tutor
  guardianId String?   @unique @map("guardian_id")
  guardian   Guardian? @relation(fields: [guardianId], references: [id])

  // Si este usuario es un estudiante, se conecta a su registro físico de Estudiante
  studentId String?  @unique @map("student_id")
  student   Student? @relation(fields: [studentId], references: [id])

  recoveryEmail      String?   @map("recovery_email") // Ej: papa@gmail.com
  resetCode          String?   @map("reset_code")
  resetCodeExpiresAt DateTime? @map("reset_code_expires_at")

  fcmTokens String[] @map("fcm_tokens")

  // 🔥 CORRECCIÓN: Relación exacta para saber qué profesor tomó la lista
  attendancesMarked AttendanceRecord[] @relation("AttendanceMarker")

  @@map("users")
}

model Institution {
  id             String         @id @default(uuid())
  rueCode        String         @unique @map("rue_code") // Código RUE / SIE (Ej. 80730145)
  name           String // Nombre oficial
  dependencyType DependencyType @map("dependency_type")

  // Ubicación Geográfica (Estructura SIE)
  department   Department
  municipality String // Ej. Sucre
  district     String // Distrito Educativo (Ej. Sucre 1)
  address      String

  // Contacto e Información
  phone       String?
  email       String?
  foundedYear Int?    @map("founded_year")

  // Capacidades Operativas autorizadas
  shifts Shift[] // Ej. [MANANA, TARDE]
  levels EducationLevel[] // Ej. [PRIMARIA, SECUNDARIA]

  // ==========================================
  // RELACIONES CON USUARIOS
  // ==========================================

  // 1. El Director actual del colegio (Conexión 1 a 1)
  directorId String? @unique @map("director_id")
  director   User?   @relation("InstitutionDirector", fields: [directorId], references: [id])

  // 2. Lista de todo el personal que trabaja aquí (Conexión 1 a Muchos)
  staff User[] @relation("InstitutionStaff")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Modo de asignación de horarios
  schedulingMode SchedulingMode @default(FIXED_BASE) @map("scheduling_mode")

  // 🔥 FASE 1: Configuración de Campaña RUDE
  enableDigitalRudeUpdates   Boolean               @default(false) @map("enable_digital_updates")
  maxRudeUpdatesPerYear      Int                   @default(2) @map("max_rude_updates_per_year")
  activeNotificationChannels NotificationChannel[] @default([PUSH_APP]) @map("active_notification_channels")

  // 🔥 FASE 2: Motor de Control de Asistencia
  enableQrAttendance        Boolean               @default(false) @map("enable_qr_attendance")
  enableBiometricAttendance Boolean               @default(false) @map("enable_biometric_attendance")
  lateToleranceMinutes      Int                   @default(5) @map("late_tolerance_minutes")
  absentToleranceMinutes    Int                   @default(15) @map("absent_tolerance_minutes")
  notificationFrequency     NotificationFrequency @default(ALERTS_ONLY) @map("notification_frequency")

  @@map("institutions")
}

// ==========================================
// MÓDULO ACADÉMICO (Estructura Base)
// ==========================================

enum AcademicStatus {
  PLANNING // Gestión futura en planificación
  ACTIVE // Gestión actual en curso
  CLOSED // Gestión histórica cerrada
}

// 1. GESTIÓN ESCOLAR (El Año Lectivo)
model AcademicYear {
  id        String         @id @default(uuid())
  year      Int            @unique // Ej. 2026
  name      String // Ej. "Gestión Académica 2026"
  startDate DateTime       @map("start_date")
  endDate   DateTime       @map("end_date")
  status    AcademicStatus @default(PLANNING)

  classrooms Classroom[]

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  enrollments Enrollment[]

  @@map("academic_years")
}

// 2. MATERIAS / ASIGNATURAS (Catálogo Global)
model Subject {
  id    String         @id @default(uuid())
  name  String // Ej. "Matemáticas", "Física"
  level EducationLevel // Para filtrar
  area  String? // Ej. "Ciencias Exactas"

  assignments TeacherAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subjects")
}

// 3. CURSO / AULA (La intersección física/lógica de todo)
model Classroom {
  id             String       @id @default(uuid())
  academicYearId String       @map("academic_year_id")
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  // Reglas RUE
  level   EducationLevel
  shift   Shift
  grade   String
  section String // PARALELO: Ej. "A", "B", "C"

  capacity Int @default(35) // Límite de alumnos por aula

  // Docente Asesor / Tutor del Curso
  advisorId String? @map("advisor_id")
  advisor   User?   @relation("ClassroomAdvisor", fields: [advisorId], references: [id])

  // Relaciones
  subjectAssignments TeacherAssignment[]

  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  scheduleSlots ScheduleSlot[]
  enrollments   Enrollment[]

  // Si la institución está en modo FIXED_BASE, este es su salón principal
  baseRoomId String?        @map("base_room_id")
  baseRoom   PhysicalSpace? @relation("ClassroomBaseRoom", fields: [baseRoomId], references: [id])

  @@unique([academicYearId, level, grade, section, shift])
  @@map("classrooms")
}

// 4. DISTRIBUCIÓN DE CARGA HORARIA
model TeacherAssignment {
  id String @id @default(uuid())

  classroomId String    @map("classroom_id")
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  subjectId String  @map("subject_id")
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  teacherId String @map("teacher_id")
  teacher   User   @relation("TeacherAssignments", fields: [teacherId], references: [id])

  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  scheduleSlots ScheduleSlot[]

  @@unique([classroomId, subjectId])
  @@map("teacher_assignments")
}

// 1. Catálogo de Periodos de Clase
model ClassPeriod {
  id        String  @id @default(uuid())
  name      String // Ej. "1er Periodo" o "Recreo"
  startTime String // Ej. "08:00"
  endTime   String // Ej. "08:40"
  shift     Shift
  isBreak   Boolean @default(false)
  order     Int

  attendanceRecords AttendanceRecord[]
  schedules         ScheduleSlot[]

  @@map("class_periods")
}

// 2. El Casillero del Horario
model ScheduleSlot {
  id        String @id @default(uuid())
  dayOfWeek Int // 1 = Lunes, 2 = Martes, ..., 5 = Viernes

  classPeriodId       String @map("class_period_id")
  teacherAssignmentId String @map("teacher_assignment_id")

  // Desnormalización estratégica
  classroomId String @map("classroom_id")
  teacherId   String @map("teacher_id")

  // Relaciones
  classPeriod       ClassPeriod       @relation(fields: [classPeriodId], references: [id])
  teacherAssignment TeacherAssignment @relation(fields: [teacherAssignmentId], references: [id], onDelete: Cascade)
  classroom         Classroom         @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  teacher           User              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  physicalSpaceId   String?           @map("physical_space_id")
  physicalSpace     PhysicalSpace?    @relation("SlotPhysicalSpace", fields: [physicalSpaceId], references: [id])

  @@unique([classroomId, dayOfWeek, classPeriodId])
  @@unique([teacherId, dayOfWeek, classPeriodId])
  @@map("schedule_slots")
}

// ==========================================
// MÓDULO 3: ESTUDIANTES E INSCRIPCIONES (RUDE)
// ==========================================

enum Gender {
  MASCULINO
  FEMENINO
}

enum EnrollmentStatus {
  REVISION_SIE
  INSCRITO
  RETIRADO
  TRASLADO
  RECHAZADO
  OBSERVADO
}

enum EnrollmentType {
  NUEVO
  ANTIGUO
  TRASPASO
  EXTRANJERO
}

// 1. EL ESTUDIANTE
model Student {
  id       String  @id @default(uuid())
  rudeCode String? @unique

  // Identificación
  documentType String  @default("CI")
  ci           String? @unique
  complement   String?
  expedition   String?

  // Nombres
  lastNamePaterno String?
  lastNameMaterno String?
  names           String

  gender          Gender
  birthDate       DateTime
  birthCountry    String   @default("BOLIVIA")
  birthDepartment String?
  birthProvince   String?
  birthLocality   String?

  // Certificado de Nacimiento Oficial
  certOficialia String?
  certLibro     String?
  certPartida   String?
  certFolio     String?

  // Capacidades Diferentes
  hasDisability       Boolean @default(false)
  disabilityCode      String?
  disabilityType      String?
  disabilityDegree    String?
  hasAutism           Boolean @default(false)
  autismType          String?
  learningDisability  Boolean @default(false)
  extraordinaryTalent Boolean @default(false)
  disabilityRegistry  String?
  disabilityOrigin    String?

  // 2.10 Dificultades de Aprendizaje
  learningDisabilityStatus String   @default("NO")
  learningDisabilityTypes  String[]
  learningSupportLocation  String[]

  // 2.11 Talento Extraordinario
  hasExtraordinaryTalent Boolean  @default(false)
  talentType             String?
  talentSpecifics        String[]
  talentIQ               String?
  talentModality         String[]

  qrTokenVersion Int @default(1) @map("qr_token_version")
  // 🔥 NUEVO: Control de estado del carnet
  hasActiveQr    Boolean @default(false) @map("has_active_qr")

  // Relaciones
  enrollments Enrollment[]
  guardians   StudentGuardian[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?
}

// 2. LA INSCRIPCIÓN (El evento Anual)
model Enrollment {
  id             String @id @default(uuid())
  studentId      String
  classroomId    String
  academicYearId String

  enrollmentType EnrollmentType
  status         EnrollmentStatus @default(REVISION_SIE)

  date DateTime @default(now())

  // Relaciones
  student      Student      @relation(fields: [studentId], references: [id])
  classroom    Classroom    @relation(fields: [classroomId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  rudeRecord RudeRecord?

  receivedDocuments Json? @map("received_documents")

  rudeUpdateCount Int                 @default(0) @map("rude_update_count")
  updateRequests  DataUpdateRequest[]

  attendanceRecords AttendanceRecord[]

  @@unique([studentId, academicYearId])
}

// 3. PADRES Y TUTORES
model Guardian {
  id              String    @id @default(uuid())
  ci              String?   @unique
  complement      String?
  expedition      String?
  lastNamePaterno String?
  lastNameMaterno String?
  names           String
  occupation      String?
  educationLevel  String?
  phone           String?
  language        String?
  birthDate       DateTime?
  jobTitle        String?
  institution     String?

  students StudentGuardian[]
  user     User?
}

model StudentGuardian {
  studentId    String
  guardianId   String
  relationship String // PADRE, MADRE, TUTOR

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@id([studentId, guardianId])
}

// 4. EL FORMULARIO RUDE
model RudeRecord {
  id           String @id @default(uuid())
  enrollmentId String @unique

  // III. Dirección Actual
  department   String?
  province     String?
  municipality String?
  locality     String?
  zone         String?
  street       String?
  houseNumber  String?
  phone        String?
  cellphone    String?

  // IV. 4.1 Idioma y Cultura
  nativeLanguage    String?
  frequentLanguages String[]
  culturalIdentity  String?

  // IV. 4.2 Salud
  medicalVisits       String?
  nearestHealthCenter Boolean  @default(false)
  healthCareLocations String[]
  healthCenterVisits  String?
  healthInsurance     Boolean  @default(false)

  // IV. 4.3 Servicios Básicos
  water       Boolean?
  bathroom    Boolean?
  sewage      Boolean?
  electricity Boolean?
  garbage     Boolean?
  housingType String?

  // IV. 4.4 Internet
  internetAccess    String[]
  internetFrequency String?

  // IV. 4.5 Trabajo
  didWork       String?
  workType      String?
  workShift     String[]
  workFrequency String?
  gotPaid       String?
  workedMonths  String[]

  // IV. 4.6 Transporte
  transportType String?
  transportTime String?

  // IV. 4.7 Abandono
  abandonedLastYear Boolean?
  abandonReasons    String[]

  // V. 5.1 Vive Habitualmente Con
  livesWith String?

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

// ==========================================
// NUEVOS ENUMS PARA GESTIÓN DE ESPACIOS
// ==========================================
enum SchedulingMode {
  FIXED_BASE
  DYNAMIC
}

enum SpaceType {
  SALON
  LABORATORIO
  CANCHA
  AUDITORIO
  OTRO
}

// ==========================================
// 🔥 NUEVA TABLA: ESPACIOS FÍSICOS
// ==========================================
model PhysicalSpace {
  id       String    @id @default(uuid())
  name     String
  type     SpaceType @default(SALON)
  isActive Boolean   @default(true)

  baseClassrooms Classroom[]    @relation("ClassroomBaseRoom")
  scheduleSlots  ScheduleSlot[] @relation("SlotPhysicalSpace")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("physical_spaces")
}

// ==========================================
// NUEVOS ENUMS PARA ACTUALIZACIÓN RUDE
// ==========================================

enum NotificationChannel {
  PUSH_APP
  WHATSAPP
  EMAIL
}

enum UpdateRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// 🔥 FASE 1: NUEVA TABLA DE CUARENTENA
model DataUpdateRequest {
  id           String @id @default(uuid())
  enrollmentId String @map("enrollment_id")

  proposedData Json @map("proposed_data")

  status UpdateRequestStatus @default(PENDING)

  createdAt       DateTime  @default(now()) @map("created_at")
  reviewedAt      DateTime? @map("reviewed_at")
  rejectionReason String?   @map("rejection_reason")

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, status])
  @@map("data_update_requests")
}

// ==========================================
// NUEVOS ENUMS PARA CONTROL DE ASISTENCIA
// ==========================================

enum AttendanceStatus {
  PRESENT // A tiempo
  LATE // Atraso (Llegó después de la tolerancia)
  ABSENT // Falta (No llegó o excedió el límite de falta)
  EXCUSED // Licencia / Justificado (Por secretaría)
}

enum AttendanceMethod {
  MANUAL // El profesor tocó la pantalla
  QR // Escaneo con la App Móvil
  BIOMETRIC // Reloj de huella/facial (Futuro)
  SYSTEM_AUTO
}

enum NotificationFrequency {
  ALERTS_ONLY // Solo avisa si hay Atraso o Falta
  ENTRY_EXIT // Avisa en el primer escaneo del día y en el último
  PER_CLASS // Avisa cada vez que el alumno entra a una nueva materia
}

// ==========================================
// MÓDULO 4: CONTROL DE ASISTENCIA
// ==========================================

model AttendanceRecord {
  id String @id @default(uuid())

  enrollmentId String     @map("enrollment_id")
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  classPeriodId String      @map("class_period_id")
  classPeriod   ClassPeriod @relation(fields: [classPeriodId], references: [id])

  date DateTime @db.Date

  status AttendanceStatus
  method AttendanceMethod @default(MANUAL)

  timestamp  DateTime @default(now())
  markedById String?  @map("marked_by_id")
  marker     User?    @relation("AttendanceMarker", fields: [markedById], references: [id])

  justification String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([enrollmentId, classPeriodId, date])
  @@map("attendance_records")
}
